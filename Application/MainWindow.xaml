<Window x:Class="Convertie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Convertie"
        WindowStyle="ThreeDBorderWindow"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        MaxWidth="{x:Static SystemParameters.PrimaryScreenWidth}"
        MaxHeight="{x:Static SystemParameters.PrimaryScreenHeight}"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        Title="Convertie"
        MinWidth="800" MinHeight="500" Width="800" Height="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ContentGrid" Margin="10,0,10,10" >
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"  x:Name="InputElementsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="InputElementTitle" Text="From:" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Visibility="Collapsed"/>
                <StackPanel x:Name="InputButtonsStack" Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0" Visibility="Collapsed">
                    <ComboBox Name="InputComboBox" VerticalAlignment="Center" HorizontalAlignment="Left"  FontWeight="SemiBold" SelectionChanged="ComboBoxSelectionChanged"/>
                    <Button x:Name="RemoveSpacesButton" Content="Remove white spaces" FontWeight="SemiBold" Margin="5,0,0,0" Padding="10,5,10,5" VerticalAlignment="Stretch" Click="RemoveSpacesButtonClick"/>
                </StackPanel>
                <TextBlock Grid.Row="2" x:Name="InputHint" Text="Type or paste to convert" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="2" x:Name="InputTextBox" Background="Transparent" BorderThickness="1" Padding="10" FontSize="14" Margin="0,5,0,0"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                         TextChanged="InputTextBoxTextChanged" GotFocus="InputTextBoxGotFocus" GotKeyboardFocus="InputTextBoxGotKeyboardFocus"/>

                <Grid x:Name="SuggestionButtonsGrid" Grid.Row="2" Margin="10" VerticalAlignment="Bottom" Visibility="Collapsed">
                    <Border x:Name="SuggestionGridBackground" Grid.Row="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Border.Effect>
                            <BlurEffect Radius="50"/>
                        </Border.Effect>
                    </Border>

                    <StackPanel Orientation="Vertical" Margin="0" >
                        <Grid x:Name="ClipboardSuggestionButtonsGrid" Height="33" VerticalAlignment="Bottom" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="ClipboardSuggestionButton" Content="Convert from clipboard" FontWeight="SemiBold"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0,0,2.5,0" Padding="5" Height="30"
                                    Click="ClipboardSuggestionButtonClick"/>

                            <Button Grid.Column="1" x:Name="ClipboardSuggestionCancelButton" FontWeight="SemiBold"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="2.5,1.5,0,1.5" Padding="8" 
                                    Click="ClipboardSuggestionCancelClick">
                                <Image x:Name="ClipboardSuggestionCancelButtonIcon"/>
                            </Button>
                        </Grid>

                        <Grid x:Name="DetectedCborDecodeSuggestionButtonsGrid" Height="33" Margin="0,2,0,0" VerticalAlignment="Bottom" 
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="DetectedCborDecodeSuggestionButton" Content="A CBOR detected in clipboard. Click to decode it." FontWeight="SemiBold"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0,0,2.5,0" Padding="5" Height="30"
                                    Click="DetectedCborDecodeSuggestionButtonClick"/>

                            <Button Grid.Column="1" x:Name="DetectedCborDecodeSuggestionCancelButton" FontWeight="SemiBold"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="2.5,1.5,0,1.5" Padding="8"
                                    Click="DetectedCborDecodeSuggestionCancelButtonClick">
                                <Image x:Name="DetectedCborDecodeSuggestionCancelButtonIcon"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="3" x:Name="InputLength" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="10,2,0,0" VerticalAlignment="Center"/>
            </Grid>

            <Grid x:Name="OutputElementsGrid" Grid.Row="1" Margin="0,10,0,0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="To:" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                    <ComboBox Name="OutputComboBox" VerticalAlignment="Center" FontWeight="SemiBold" SelectionChanged="ComboBoxSelectionChanged"/>
                    <ComboBox Name="TextEncodingDecodingCombobox" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" SelectionChanged="ComboBoxSelectionChanged" Visibility="Collapsed"/>
                    <Button x:Name="ReverseButton" Padding="6" Width="33" Height="33" Margin="10,0,0,0" 
                            VerticalAlignment="Center" HorizontalAlignment="Left" Click="ReverseButtonClick">
                        <Image x:Name="ReverseButtonIcon" />
                    </Button>
                    <Button x:Name="CopyButton" Padding="5" Width="33" Height="33" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" Click="CopyButtonClick">
                        <Image x:Name="CopyButtonIcon" />
                    </Button>
                </StackPanel>
                <TextBox Grid.Row="2" x:Name="OutputTextBox" Background="Transparent" BorderThickness="1" Padding="10" FontSize="14" Margin="0,5,0,0"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"/>
                <TextBlock Grid.Row="3" x:Name="OutputLength" FontWeight="SemiBold" Margin="10,2,0,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10,0,10,0">
            <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsEnabled="False"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="10">
                    <TextBlock FontWeight="Bold" Text="Auto convert" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="AutoConvertHintText" Text="Set input and output types to trigger an auto conversion by analyzing the clipboard when the input text box is focused"
                               TextAlignment="Left" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="Wrap" MaxWidth="400"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10">
                    <TextBlock x:Name="AutoConvertInputComboboxTitle" Text="From" Margin="0,0,5,0" FontWeight="SemiBold" VerticalAlignment="Center" Visibility="Collapsed"/>
                    <ComboBox Name="AutoConvertInputTypeComboBox" FontWeight="SemiBold" VerticalAlignment="Center" SelectionChanged="AutoConvertInputTypeComboBoxSelectionChanged"/>
                    <StackPanel x:Name="AutoConvertOutputElementsStack" Orientation="Horizontal" Visibility="Collapsed">
                        <TextBlock Text="to" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center" />
                        <ComboBox Name="AutoConvertOutputTypeComboBox" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center" SelectionChanged="AutoConvertOutputTypeComboBoxSelectionChanged"/>

                        <ComboBox Name="AutoConvertTextEncodingDecodingCombobox" VerticalAlignment="Center" FontWeight="SemiBold" Margin="5,0,0,0" SelectionChanged="AutoConvertTextEncodingDecodingComboboxSelectionChanged" Visibility="Visible"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="10" Padding="5" Click="PanelViewChangeButtonClick" ToolTip="Change the panel orientation.">
                <Image x:Name="PanelChangeIcon"/>
            </Button>
            
            <Button Grid.Column="1" x:Name="WindowPinToggleButton" Margin="0,10,10,10" Padding="5" Click="WindowPinToggleButtonClick">
                <Image x:Name="WindowPinToggleButtonIcon"/>
            </Button>

            <Button Grid.Column="2" x:Name="ClipBoardSuggestionToggleButton" Margin="0,10,10,10" Padding="5" Click="ClipBoardSuggestionToggleButtonClick">
                <Image x:Name="ClipBoardSuggestionToggleButtonIcon"/>
            </Button>

            <Grid Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,10,10,10">
                <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsEnabled="False"/>
                <TextBlock x:Name="MessageTextBox" FontWeight="SemiBold" Text="Convert as you wish ;)" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,10,0"/>
                <TextBlock x:Name="ErrorTextBox" FontWeight="SemiBold" Foreground="Red" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,10,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
